# =============================================================
# ANGELIC BUYBACK ENGINE -- ENVIRONMENT CONFIGURATION
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.
# =============================================================

# -- RPC & NETWORK -----------------------------------------------

# JSON-RPC endpoint for your target chain
# Use a dedicated node provider (Alchemy, QuickNode, Helius, etc.)
RPC_URL=https://mainnet.example-rpc.com

# Chain ID (e.g. 1 for Ethereum mainnet, 8453 for Base, etc.)
CHAIN_ID=1

# -- WALLETS -----------------------------------------------------

# Operator wallet private key (transaction signer)
# This wallet pays gas and signs buyback transactions.
# Use a dedicated hot wallet. Never use a personal or main wallet.
PRIVATE_KEY=0xyour_private_key_here

# Fee sink / buyback funding wallet (public, read-only monitoring)
# Default: Angelic Investor canonical fee wallet
FEE_WALLET=D1gPeYYJP15ZZDVQwkWcUrpjus3E6xnirkTWTAqi3xrG

# -- TOKEN -------------------------------------------------------

# Contract address of the token to buy back
TOKEN_ADDRESS=0xyour_token_contract_here

# DEX router contract address (placeholder for Phase 3 adapter)
ROUTER_ADDRESS=0xyour_router_address_here

# -- STRATEGY ----------------------------------------------------

# Minimum fee wallet balance (native token) before buyback is considered
MIN_TRIGGER_BALANCE=0.5

# Maximum native token spend per buyback cycle
MAX_BUYBACK_SIZE=0.2

# Fraction of available balance to allocate per cycle (0.0 to 1.0)
BUYBACK_RATIO=0.8

# Cooldown in seconds between buyback cycle executions
BUYBACK_COOLDOWN_SEC=3600

# Number of equal tranches to split each buyback cycle into
BUYBACK_TRANCHE_COUNT=3

# Maximum acceptable slippage in basis points (100 = 1%)
MAX_SLIPPAGE_BPS=100

# -- RUNTIME -----------------------------------------------------

# Wallet polling interval in seconds
CHECK_INTERVAL_SEC=60

# Set to true to simulate all logic without any on-chain execution
DRY_RUN=false

# Logging verbosity: info | debug | warn | error
LOG_LEVEL=info
